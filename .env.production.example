COMPOSE_PROJECT_NAME=personal-blog-prod
APP_VERSION=0.1.0
IMAGE_REGISTRY=local

PUBLIC_HOST=blog.example.com
ADMIN_HOST=admin.blog.example.com

MYSQL_DATABASE=personal_blog
MYSQL_USERNAME=blog
MYSQL_PASSWORD=replace-with-a-long-random-password
MYSQL_ROOT_PASSWORD=replace-with-another-long-random-password

REDIS_USERNAME=default
REDIS_PASSWORD=replace-with-a-long-random-password

JWT_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Set only for the first deployment, then remove both values.
ADMIN_INITIAL_USERNAME=
ADMIN_INITIAL_PASSWORD=
ADMIN_INITIAL_NICKNAME=Administrator

OSS_REGION=
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_CDN_DOMAIN=
OSS_OBJECT_PREFIX=blog/prod
OSS_ORPHAN_GRACE_PERIOD=24h
OSS_DELETE_RETRY_BASE_DELAY=1m
OSS_STALE_DELETE_TIMEOUT=15m
OSS_CLEANUP_BATCH_SIZE=50
OSS_CLEANUP_INTERVAL=300000

MAIL_ENABLED=false
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_SMTP_AUTH=true
MAIL_STARTTLS=true

BLOG_PROJECT=blog
BLOG_ENVIRONMENT=prod
CACHE_ENABLED=true
ARTICLE_CACHE_TTL=10m
LIST_CACHE_TTL=5m
TAXONOMY_CACHE_TTL=30m
STATISTICS_FLUSH_INTERVAL=60000

# Used by deploy/scripts/backup-mysql.sh. Keep this outside the repository.
BACKUP_DIR=/var/backups/personal-blog
BACKUP_ENCRYPTION_PASSWORD=replace-with-a-separate-long-random-secret
# Optional: oss://a-separate-backup-bucket/personal-blog
BACKUP_OSS_URI=
