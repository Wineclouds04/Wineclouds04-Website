# Copy this file to .env.production on the Ubuntu host. Do not commit the copy.
COMPOSE_PROJECT_NAME=wineclouds-blog
APP_VERSION=2026.07.16.1
IMAGE_REGISTRY=local

# public-fullchain.pem/public-privkey.pem must cover both frontend names.
# admin-fullchain.pem/admin-privkey.pem must cover the admin name.
PUBLIC_HOST=wineclouds.cn
PUBLIC_WWW_HOST=www.wineclouds.cn
ADMIN_HOST=admin.wineclouds.cn

MYSQL_DATABASE=personal_blog
MYSQL_USERNAME=blog
MYSQL_PASSWORD=replace-with-a-long-random-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-long-random-password

REDIS_USERNAME=default
REDIS_PASSWORD=replace-with-a-long-random-password

# Generate a random value of at least 32 bytes; do not reuse a database password.
JWT_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Used only when the sys_user table is empty. Remove these two values after the first login.
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD=replace-with-a-strong-initial-password
ADMIN_INITIAL_NICKNAME=Administrator

# Tencent Cloud COS (optional; leave all values blank to disable uploads).
# COS_BUCKET must include the AppId suffix, for example: blog-1250000000.
COS_REGION=ap-shanghai
COS_BUCKET=
COS_SECRET_ID=
COS_SECRET_KEY=
COS_CDN_DOMAIN=
COS_OBJECT_PREFIX=blog/prod
COS_ORPHAN_GRACE_PERIOD=24h
COS_DELETE_RETRY_BASE_DELAY=1m
COS_STALE_DELETE_TIMEOUT=15m
COS_CLEANUP_BATCH_SIZE=50
COS_CLEANUP_INTERVAL=300000

# SMTP (optional; set MAIL_ENABLED=true only after all fields are configured).
MAIL_ENABLED=false
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_SMTP_AUTH=true
MAIL_STARTTLS=true

CACHE_ENABLED=true
ARTICLE_CACHE_TTL=10m
LIST_CACHE_TTL=5m
TAXONOMY_CACHE_TTL=30m
STATISTICS_FLUSH_INTERVAL=60000
SWAGGER_ENABLED=false

# Required by deploy/scripts/backup-mysql.sh. BACKUP_DIR must be outside the repository.
BACKUP_DIR=/var/backups/wineclouds-blog
BACKUP_ENCRYPTION_PASSWORD=replace-with-a-dedicated-backup-encryption-password
BACKUP_OSS_URI=
