{
  "name": "personal-blog",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "frontend/web",
    "frontend/admin",
    "frontend/packages/*"
  ],
  "scripts": {
    "build": "npm run build:web && npm run build:admin",
    "build:web": "npm run build --workspace @personal-blog/web",
    "build:admin": "npm run build --workspace @personal-blog/admin",
    "dev:web": "npm run dev --workspace @personal-blog/web",
    "dev:admin": "npm run dev --workspace @personal-blog/admin",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:openapi": "redocly lint docs/openapi.yaml",
    "test:lighthouse": "lhci autorun",
    "test:performance": "docker run --rm -i -e BASE_URL -e ARTICLE_SLUG grafana/k6:1.7.1 run - < tests/performance/blog.js"
  },
  "overrides": {
    "tmp": "0.2.7",
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@redocly/cli": "^2.36.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.9"
  }
}
