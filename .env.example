COMPOSE_PROJECT_NAME=wineclouds04-website
HTTP_PORT=80

MYSQL_DATABASE=personal_blog
MYSQL_USERNAME=blog
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-password

REDIS_USERNAME=default
REDIS_PASSWORD=change-redis-password

SPRING_PROFILES_ACTIVE=docker

JWT_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
SECURE_COOKIES=false
ADMIN_ALLOWED_ORIGINS=http://localhost,http://admin.localhost

# Used once when sys_user is empty. Remove after the first successful login.
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD=change-this-before-starting
ADMIN_INITIAL_NICKNAME=Administrator

# Tencent Cloud COS (server-side only; leave blank to disable uploads).
# COS_BUCKET must include the AppId suffix, for example: blog-1250000000.
COS_REGION=
COS_BUCKET=
COS_SECRET_ID=
COS_SECRET_KEY=
COS_CDN_DOMAIN=
COS_OBJECT_PREFIX=blog/dev
COS_ORPHAN_GRACE_PERIOD=24h
COS_DELETE_RETRY_BASE_DELAY=1m
COS_STALE_DELETE_TIMEOUT=15m
COS_CLEANUP_BATCH_SIZE=50
COS_CLEANUP_INTERVAL=300000
MAIL_ENABLED=false
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_SMTP_AUTH=true
MAIL_STARTTLS=true
BLOG_PROJECT=blog
BLOG_ENVIRONMENT=prod
CACHE_ENABLED=true
ARTICLE_CACHE_TTL=10m
LIST_CACHE_TTL=5m
TAXONOMY_CACHE_TTL=30m
STATISTICS_FLUSH_INTERVAL=60000
SWAGGER_ENABLED=true
# Public site
SITE_URL=http://localhost
NUXT_PUBLIC_SOCIAL_GITHUB_URL=
NUXT_PUBLIC_SOCIAL_DOUYIN_URL=
NUXT_PUBLIC_SOCIAL_BILIBILI_URL=
NUXT_PUBLIC_SOCIAL_XIAOHONGSHU_URL=
